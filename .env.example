# Production (Render PostgreSQL)
DATABASE_URL="postgresql://afmd:afmd@localhost:5432/afmd"

# Auth — use a long random string in production
JWT_SECRET="change-me-in-production-use-openssl-rand"

# Admin account (seeded on first deploy)
ADMIN_EMAIL="admin@afrimindai.com"
ADMIN_PASSWORD="Admin@2026!"

# Public site URL (your Vercel domain in production)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Deployment split ───────────────────────────────────────────────
# Render (backend): set DEPLOY_TARGET=render, no BACKEND_URL needed
DEPLOY_TARGET=""

# Vercel (frontend): URL of your Render web service (no trailing slash)
BACKEND_URL="https://af-md-api.onrender.com"

# Render (backend): your Vercel frontend URL for CORS (no trailing slash)
FRONTEND_URL="https://your-app.vercel.app"

# Optional — course uploads (Render persistent disk mounts public/uploads)
UPLOAD_DIR=""

# Optional integrations
OPENAI_API_KEY=""
SMTP_HOST=""
TWILIO_ACCOUNT_SID=""
NEXT_PUBLIC_FORMSPREE_ID=""
NEXT_PUBLIC_WHATSAPP_NUMBER=""
